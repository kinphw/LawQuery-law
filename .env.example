# 이 파일을 .env 로 복사해서 사용 (.env 는 git 제외)
#   copy .env.example .env   (Windows)

# --- 개발(기본 타깃) : 로컬 MariaDB ---
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=genius

# --- 운영(--target prod 일 때 사용) ---
# 비워두면 위 기본값을 그대로 사용한다.
MYSQL_HOST_PROD=192.168.0.7
MYSQL_PORT_PROD=3306
MYSQL_USER_PROD=root
MYSQL_PASSWORD_PROD=
