# 이 파일을 .env 로 복사해서 사용 (.env 는 git 제외)
#   copy .env.example .env   (Windows)

# --- 개발(기본 타깃) : 로컬 MariaDB ---
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=genius

# --- 운영(--target prod / GUI 운영배포 시 사용) ---
# MYSQL_*_PROD = 운영 서버의 MySQL 자격(서버 로컬 MySQL). 비번 채워야 운영 적재/복제 가능.
MYSQL_HOST_PROD=192.168.0.7
MYSQL_PORT_PROD=3306
MYSQL_USER_PROD=root
MYSQL_PASSWORD_PROD=

# --- 운영 SSH 터널 (운영 MySQL이 localhost 바인딩 → 3306 직접 미도달 시 필수) ---
# GUI '운영 배포'(개발 ldb_<code> → 운영 정확복제)가 이 터널로 mysqldump→mysql 파이프한다.
# SSH_HOST 비우면 터널 없이 MYSQL_HOST_PROD 직접 연결 시도.
SSH_HOST=192.168.0.7
SSH_PORT=22
SSH_USER=kinphw
SSH_PASSWORD=
SSH_BIND_PORT=13306

# 국가법령정보센터 OPEN API 인증값 (law.go.kr 신청)
LAW_OC=your_oc_here
